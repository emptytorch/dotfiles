// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "diagnostics": {
    "button": false,
  },
  "global_lsp_settings": {
    "button": false,
  },
  "search": {
    "button": false,
  },
  "agent": {
    "sidebar_side": "left",
    "button": false,
    "favorite_models": [],
    "model_parameters": [],
  },
  "gutter": {
    "bookmarks": false,
    "folds": false,
    "min_line_number_digits": 0,
  },
  "status_bar": {
    "active_language_button": false,
  },
  "toolbar": {
    "breadcrumbs": false,
    "quick_actions": false,
  },
  "title_bar": {
    "show_sign_in": false,
    "show_user_menu": false,
  },
  "edit_predictions": {
    "provider": "none",
  },
  "file_finder": {
    "modal_max_width": "large",
  },
  "cursor_blink": false,
  "relative_line_numbers": "enabled",
  "tab_bar": {
    "show": false,
  },
  "project_panel": {
    "button": false,
    "dock": "left",
    "sticky_scroll": false,
    "scrollbar": {
      "show": "never",
    },
    "starts_open": false,
    "auto_fold_dirs": false,
  },
  "scrollbar": {
    "show": "never",
  },
  "git_panel": {
    "button": false,
  },
  "collaboration_panel": {
    "button": false,
  },
  "debugger": {
    "button": false,
  },
  "terminal": {
    "button": false,
  },
  "outline_panel": {
    "button": false,
  },
  "base_keymap": "VSCode",
  "vim_mode": true,
  "vim": {},
  "vertical_scroll_margin": 5,
  "scroll_beyond_last_line": "off",
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "ui_font_size": 16,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Gruber Darker",
  },
}
