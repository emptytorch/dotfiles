[
  {
    "context": "Workspace",
    "bindings": {
      "space e": "project_panel::Toggle",
    },
  },
  {
    "context": "GitPanel",
    "bindings": {
      "q": "git_panel::Close",
    },
  },
  {
    "context": "Editor && vim_mode == normal",
    "bindings": {
      "space f f": "file_finder::Toggle",
      "space s g": "pane::DeploySearch",
      "space c r": "editor::Rename",
      "space c a": "editor::ToggleCodeActions",
      "space w v": "pane::SplitVertical",
      "space w s": "pane::SplitHorizontal",
      "space w d": "pane::CloseActiveItem",
      "space g g": "git_panel::Toggle",
      "space x x": "diagnostics::Deploy",
      "space x X": "diagnostics::DeployCurrentFile",
      "shift-k": "editor::Hover",
      "g r": "editor::FindAllReferences",
      "[d": "editor::GoToPreviousDiagnostic",
      "]d": "editor::GoToDiagnostic",
    },
  },
  {
    "context": "Editor && vim_mode == visual && !VimWaiting",
    "bindings": {
      ">": ["editor::Indent", "vim::SelectLastVisualSelection"],
      "<": ["editor::Outdent", "vim::SelectLastVisualSelection"],
    },
  },
]
